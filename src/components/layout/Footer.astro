---
import Container from './Container.astro';
const year = new Date().getFullYear();
---
<footer><Container><div><div><strong>Coleção Selos</strong><p>Catálogo filatélico digital para pesquisa, organização e preservação documental.</p></div><nav aria-label="Links do rodapé"><a href="/catalogo">Catálogo</a><a href="/sobre">Metodologia</a></nav></div><small>© {year} Coleção Selos · Catálogo em desenvolvimento</small></Container></footer>
<style>footer{padding-block:3rem;border-top:1px solid var(--color-border);background:#ede7dc}footer .container>div{display:flex;justify-content:space-between;gap:2rem}strong{font:500 1.4rem var(--serif)}p{margin:.35rem 0 1.5rem;color:var(--color-muted)}nav{display:flex;gap:1.2rem;align-items:flex-start}small{color:var(--color-muted)}@media(max-width:36rem){footer .container>div{display:block}nav{margin-bottom:1.5rem}}</style>
