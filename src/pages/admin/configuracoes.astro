---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Configurações"><header class="page-head"><div><p class="eyebrow">Ambiente</p><h1>Configurações</h1><p class="muted">Estado seguro da configuração, sem exibir valores secretos.</p></div></header><section class="config-grid" data-config><div class="panel loading">Carregando configurações…</div></section>
<script>
 const target=document.querySelector<HTMLElement>('[data-config]');const labels:{[key:string]:string}={site_url_configurada:'URL do site',autenticacao_configurada:'Autenticação',bootstrap_password_configurada:'Segredo ambiental de bootstrap',persistencia_credenciais:'Persistência das credenciais',bootstrap_seguro:'Bootstrap protegido',role_padrao:'Perfil padrão',duracao_sessao_segundos:'Duração da sessão (s)'};fetch('/api/admin/configuracoes').then(async response=>{const payload=await response.json();if(response.status===401){window.dispatchEvent(new Event('admin:session-expired'));return}if(!response.ok)throw new Error(payload.error?.message);if(target)target.innerHTML=Object.entries(payload.data).map(([key,value])=>`<dl class="panel config-card"><dt>${labels[key]||key}</dt><dd>${typeof value==='boolean'?(value?'Configurada':'Pendente'):String(value)}</dd></dl>`).join('')}).catch(error=>{if(target)target.innerHTML=`<div class="error">${error.message||'Erro ao carregar configurações.'}</div>`});
</script></AdminLayout>
