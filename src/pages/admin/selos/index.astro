---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout title="Selos">
  <header class="page-head"><div><p class="eyebrow">Catálogo administrativo</p><h1>Selos</h1><p class="muted">Leitura dos registros oficiais; edição ficará disponível em um próximo bloco.</p></div></header>
  <form class="panel filters" data-filters><label>Buscar por ID ou título<input type="search" name="q" maxlength="100" autocomplete="off" placeholder="SEL-000001 ou Campos Salles"/></label><label>Status<select name="status"><option value="">Todos</option></select></label><label>Ordenar<select name="sort"><option value="id">ID</option><option value="titulo">Título</option><option value="pais">País</option><option value="ano">Ano</option><option value="status">Status</option><option value="atualizado_em">Atualização</option></select></label><button class="button" type="reset">Limpar</button></form>
  <section class="panel" data-results><div class="loading">Carregando registros…</div></section>
  <nav class="panel pager" data-pager hidden aria-label="Paginação"><button type="button" data-prev>Anterior</button><span data-page></span><button type="button" data-next>Próxima</button></nav>
  <script>
    const form = document.querySelector<HTMLFormElement>('[data-filters]'); const results = document.querySelector<HTMLElement>('[data-results]'); const pager = document.querySelector<HTMLElement>('[data-pager]'); const statusSelect = form?.elements.namedItem('status') as HTMLSelectElement | null;
    let page = 1; let pages = 1; let timer: number;
    const entities: Record<string, string> = { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' };
    const escape = (value: unknown) => String(value ?? '—').replace(/[&<>"']/g, (char) => entities[char] ?? char);
    const imageSummary = (item: any) => { const required = item.imagens.frente.valido && item.imagens.card.valido; const optional = ['verso', 'thumb'].filter((kind) => item.imagens[kind].informado).map((kind) => item.imagens[kind].valido ? kind : `${kind} com erro`); return `${required ? 'Frente + card válidos' : 'Assets obrigatórios com erro'}${optional.length ? ` + ${optional.join(', ')}` : ''}`; };
    const validationTitle = (item: any) => `Estrutural: ${item.validacao.estrutural.rotulo}; semântica: ${item.validacao.semantica.rotulo}; editorial: ${item.validacao.editorial.rotulo}; assets: ${item.validacao.assets.rotulo}`;
    async function load() {
      if (!form || !results) return; results.innerHTML = '<div class="loading">Carregando registros…</div>';
      const data = new FormData(form); const params = new URLSearchParams({ q:String(data.get('q') || ''), status:String(data.get('status') || ''), sort:String(data.get('sort') || 'id'), page:String(page), pageSize:'20' });
      try {
        const response = await fetch(`/api/admin/selos?${params}`); const payload = await response.json();
        if (response.status === 401) { window.dispatchEvent(new Event('admin:session-expired')); return; }
        if (!response.ok) throw new Error(payload.error?.message || 'Erro ao carregar selos.');
        if (statusSelect && statusSelect.options.length === 1) payload.meta.filters.statuses.forEach((status: string) => statusSelect.add(new Option(status.replaceAll('_', ' '), status)));
        pages = payload.meta.pages;
        results.innerHTML = payload.data.length ? `<div class="table-wrap"><table class="admin-table"><thead><tr><th>ID</th><th>Título</th><th>País</th><th>Ano</th><th>Status</th><th>Atualização</th><th>Imagens</th><th>Validação</th><th></th></tr></thead><tbody>${payload.data.map((item: any) => `<tr><td><strong>${escape(item.id)}</strong></td><td>${escape(item.titulo)}</td><td>${escape(item.pais)}</td><td>${escape(item.ano)}</td><td><span class="badge">${escape(item.status)}</span></td><td>${escape(item.atualizado_em)}</td><td>${escape(imageSummary(item))}</td><td><span class="badge ${item.validacao.valida ? 'ok' : 'bad'}" title="${escape(validationTitle(item))}">${item.validacao.valida ? 'Válido' : `${escape(item.validacao.erros)} erro(s)`}</span></td><td><a href="/admin/selos/${encodeURIComponent(item.id)}">Visualizar</a></td></tr>`).join('')}</tbody></table></div>` : '<div class="empty"><h2>Nenhum registro encontrado</h2><p>Ajuste a busca ou os filtros.</p></div>';
        if (pager) { pager.hidden = false; const label = pager.querySelector<HTMLElement>('[data-page]'); if (label) label.textContent = `Página ${payload.meta.page} de ${pages}`; (pager.querySelector('[data-prev]') as HTMLButtonElement).disabled = page <= 1; (pager.querySelector('[data-next]') as HTMLButtonElement).disabled = page >= pages; }
      } catch (error) { results.innerHTML = `<div class="error">${escape(error instanceof Error ? error.message : 'Erro inesperado.')}</div>`; }
    }
    form?.addEventListener('input', () => { clearTimeout(timer); page = 1; timer = window.setTimeout(load, 250); }); form?.addEventListener('reset', () => { page = 1; requestAnimationFrame(load); }); pager?.querySelector('[data-prev]')?.addEventListener('click', () => { if (page > 1) { page--; load(); } }); pager?.querySelector('[data-next]')?.addEventListener('click', () => { if (page < pages) { page++; load(); } }); load();
  </script>
</AdminLayout>
