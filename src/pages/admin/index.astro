---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---
<AdminLayout title="Visão geral"><header class="page-head"><div><p class="eyebrow">Painel administrativo</p><h1>Visão geral</h1><p class="muted">Indicadores calculados a partir dos registros oficiais.</p></div></header><section data-dashboard><div class="panel loading">Carregando indicadores…</div></section><h2 class="section-title">Atividade recente</h2><section class="panel" data-activity><div class="loading">Carregando atividade…</div></section>
<script>
 const dashboard=document.querySelector<HTMLElement>('[data-dashboard]');const activity=document.querySelector<HTMLElement>('[data-activity]');
 const escape=(value:unknown)=>String(value??'').replace(/[&<>'"]/g,char=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[char]||char));
 fetch('/api/admin/dashboard').then(async response=>{const payload=await response.json();if(response.status===401){window.dispatchEvent(new Event('admin:session-expired'));return}if(!response.ok)throw new Error(payload.error?.message||'Erro ao carregar painel.');const labels:{[key:string]:string}={total:'Total de selos',rascunhos:'Rascunhos',em_preparacao:'Em preparação',aguardando_revisao:'Aguardando revisão',aprovados:'Aprovados',publicados:'Publicados',rejeitados_ou_correcoes:'Rejeitados / correções',com_erro:'Registros com erro'};if(dashboard)dashboard.innerHTML=`<div class="stats">${Object.entries(payload.data.indicadores).map(([key,value])=>`<article class="panel stat"><strong>${escape(value)}</strong><span>${escape(labels[key]||key)}</span></article>`).join('')}</div>`;if(activity)activity.innerHTML=payload.data.atividade_recente.length?`<ul class="activity">${payload.data.atividade_recente.map((item:any)=>`<li><strong>${escape(item.id)}</strong><span>${escape(item.titulo)} — ${escape(item.tipo)}</span><time datetime="${escape(item.ocorrido_em)}">${escape(new Date(item.ocorrido_em).toLocaleDateString('pt-BR'))}</time></li>`).join('')}</ul>`:'<div class="empty">Nenhuma atividade editorial registrada.</div>'}).catch(error=>{const html=`<div class="error">${escape(error.message)}</div>`;if(dashboard)dashboard.innerHTML=html;if(activity)activity.innerHTML=html});
</script></AdminLayout>
