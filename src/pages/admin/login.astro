---
export const prerender = false;
import '../../styles/admin.css';
const returnTo = Astro.url.searchParams.get('returnTo');
const safeReturnTo = returnTo?.startsWith('/admin') && !returnTo.startsWith('//') ? returnTo : '/admin';
---
<!doctype html><html lang="pt-BR"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width"/><meta name="robots" content="noindex,nofollow"/><title>Entrar | Administração</title></head><body class="login-page"><main class="login-card"><p class="eyebrow">Coleção Selos</p><h1>Acesso administrativo</h1><p class="muted">Use suas credenciais administrativas.</p><div class="error" data-error hidden role="alert"></div><form data-login data-return={safeReturnTo}><label>Usuário<input name="username" autocomplete="username" required maxlength="100"/></label><label>Senha<input type="password" name="password" autocomplete="current-password" required maxlength="500"/></label><button type="submit">Entrar</button></form><p><a href="/">← Voltar ao catálogo</a></p></main>
<script>
 const form=document.querySelector<HTMLFormElement>('[data-login]');const error=document.querySelector<HTMLElement>('[data-error]');
 if(new URLSearchParams(location.search).has('expired')&&error){error.hidden=false;error.textContent='Sua sessão expirou. Entre novamente.'}
 form?.addEventListener('submit',async(event)=>{event.preventDefault();const button=form.querySelector('button');if(button)button.disabled=true;if(error)error.hidden=true;const data=new FormData(form);try{const response=await fetch('/api/admin/auth/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:data.get('username'),password:data.get('password')})});const payload=await response.json();if(!response.ok)throw new Error(payload.error?.message||'Falha de autenticação.');location.assign(payload.data.bootstrapRequired?'/admin/primeiro-acesso':(form.dataset.return||'/admin'))}catch(cause){if(error){error.hidden=false;error.textContent=cause instanceof Error?cause.message:'Falha de autenticação.'}if(button)button.disabled=false}});
</script></body></html>
