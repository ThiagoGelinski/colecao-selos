---
export const prerender = false;
import '../../styles/admin.css';
---
<!doctype html><html lang="pt-BR"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width"/><meta name="robots" content="noindex,nofollow"/><title>Primeiro acesso | Administração</title></head><body class="login-page"><main class="login-card"><p class="eyebrow">Coleção Selos</p><h1>Configure seu acesso administrativo</h1><p class="muted">Crie seu usuário definitivo e uma senha segura para continuar.</p><div class="error" data-error hidden role="alert"></div><form data-first-access><label>Novo usuário/login<input name="username" autocomplete="username" required minlength="4" maxlength="64" pattern="[A-Za-z0-9._-]+" aria-describedby="username-help"/></label><small id="username-help" class="muted">Use letras, números, ponto, hífen ou underscore.</small><label>Nova senha<input type="password" name="newPassword" autocomplete="new-password" required minlength="12" maxlength="500"/></label><label>Confirme a nova senha<input type="password" name="confirmation" autocomplete="new-password" required minlength="12" maxlength="500"/></label><button type="submit">Criar meu acesso</button></form><button class="text-button" type="button" data-logout>Sair</button></main>
<script>
 const form=document.querySelector<HTMLFormElement>('[data-first-access]');const error=document.querySelector<HTMLElement>('[data-error]');const logout=document.querySelector<HTMLButtonElement>('[data-logout]');
 form?.addEventListener('submit',async(event)=>{event.preventDefault();const button=form.querySelector('button');if(button)button.disabled=true;if(error)error.hidden=true;const data=new FormData(form);try{const response=await fetch('/api/admin/auth/first-access',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({username:data.get('username'),newPassword:data.get('newPassword'),confirmation:data.get('confirmation')})});const payload=await response.json();if(!response.ok)throw new Error(payload.error?.message||'Não foi possível criar o acesso.');location.assign('/admin')}catch(cause){if(error){error.hidden=false;error.textContent=cause instanceof Error?cause.message:'Não foi possível criar o acesso.'}if(button)button.disabled=false}});
 logout?.addEventListener('click',async()=>{logout.disabled=true;try{await fetch('/api/admin/auth/logout',{method:'POST'})}finally{location.assign('/admin/login')}});
</script></body></html>
