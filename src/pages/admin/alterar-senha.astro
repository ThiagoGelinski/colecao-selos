---
export const prerender = false;
import '../../styles/admin.css';
---
<!doctype html><html lang="pt-BR"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width"/><meta name="robots" content="noindex,nofollow"/><title>Alterar senha | Administração</title></head><body class="login-page"><main class="login-card"><p class="eyebrow">Coleção Selos</p><h1>Alterar senha</h1><p class="muted">Confirme sua senha atual e escolha uma nova senha.</p><div class="error" data-error hidden role="alert"></div><form data-change-password><label>Senha atual<input type="password" name="currentPassword" autocomplete="current-password" required maxlength="500"/></label><label>Nova senha<input type="password" name="newPassword" autocomplete="new-password" required minlength="12" maxlength="500" aria-describedby="password-help"/></label><small id="password-help" class="muted">Use pelo menos 12 caracteres. A senha não pode ser igual ao usuário.</small><label>Confirme a nova senha<input type="password" name="confirmation" autocomplete="new-password" required minlength="12" maxlength="500"/></label><button type="submit">Salvar nova senha</button></form><button class="text-button" type="button" data-logout>Sair</button></main>
<script>
 const form=document.querySelector<HTMLFormElement>('[data-change-password]');const error=document.querySelector<HTMLElement>('[data-error]');const logout=document.querySelector<HTMLButtonElement>('[data-logout]');
 form?.addEventListener('submit',async(event)=>{event.preventDefault();const button=form.querySelector('button');if(button)button.disabled=true;if(error)error.hidden=true;const data=new FormData(form);try{const response=await fetch('/api/admin/auth/change-password',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({currentPassword:data.get('currentPassword'),newPassword:data.get('newPassword'),confirmation:data.get('confirmation')})});const payload=await response.json();if(!response.ok)throw new Error(payload.error?.message||'Não foi possível alterar a senha.');location.assign('/admin')}catch(cause){if(error){error.hidden=false;error.textContent=cause instanceof Error?cause.message:'Não foi possível alterar a senha.'}if(button)button.disabled=false}});
 logout?.addEventListener('click',async()=>{logout.disabled=true;try{await fetch('/api/admin/auth/logout',{method:'POST'})}finally{location.assign('/admin/login')}});
</script></body></html>
