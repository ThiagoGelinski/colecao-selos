PUBLICATION_MODE=preview
SITE_URL=https://colecaodeselos.netlify.app

# Administração — configure os segredos somente no .env local e no Netlify.
ADMIN_SESSION_SECRET=SUBSTITUA_POR_UM_SEGREDO_ALEATORIO_COM_32_OU_MAIS_CARACTERES
# Obrigatória apenas na primeira inicialização; use no mínimo 16 caracteres e remova após a troca definitiva.
ADMIN_BOOTSTRAP_PASSWORD=SUBSTITUA_POR_UM_SEGREDO_TEMPORARIO_COM_16_OU_MAIS_CARACTERES
ADMIN_ROLE=administrador
ADMIN_SESSION_TTL_SECONDS=28800